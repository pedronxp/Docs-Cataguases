generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// O modelo User foi movido para baixo para manter as relações próximas

model LivrosNumeracao {
  id               String        @id @default(cuid())
  nome             String        @unique
  tipoDocumento    TipoDocumento @unique @default(PORTARIA)
  formato_base     String        @default("PORT-{N}/CATAGUASES")
  proximo_numero   Int           @default(1)
  numero_inicial   Int           @default(1)
  logs             Json          @default("[]")
  ativo            Boolean       @default(true)
  criado_em        DateTime      @default(now())
  atualizado_em    DateTime      @updatedAt
}

model Portaria {
  id              String   @id @default(cuid())
  titulo          String
  descricao       String?
  numeroOficial   String?
  status          String   @default("RASCUNHO") // RASCUNHO, PROCESSANDO, ASSINADO, PUBLICADO, ARQUIVADO
  criadoPorId     String
  secretariaId    String
  setorId         String?
  modeloId        String
  modelo          ModeloDocumento @relation(fields: [modeloId], references: [id])
  criadoPor       User            @relation("CriadoPor", fields: [criadoPorId], references: [id])
  secretaria      Secretaria      @relation(fields: [secretariaId], references: [id])
  setor           Setor?          @relation(fields: [setorId], references: [id])
  pdfUrl          String?
  docxRascunhoUrl String?
  hashIntegridade String?  @unique // SHA-256 do conteúdo
  assinadoEm      DateTime?
  assinadoPorId   String?
  assinadoPor     User?           @relation("AssinadoPor", fields: [assinadoPorId], references: [id])
  dataPublicacao  DateTime?
  formData        Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  atividades      FeedAtividade[]

  // Controle de Revisão
  revisorAtualId           String?
  revisorAtual             User?           @relation("RevisorAtual", fields: [revisorAtualId], references: [id])
  revisoesCount            Int             @default(0)
  
  // Controle de Assinatura Avançado
  assinaturaStatus         String          @default("NAO_ASSINADA") // NAO_ASSINADA, ASSINADA_DIGITAL, ASSINADA_MANUAL, DISPENSADA_COM_JUSTIFICATIVA
  assinaturaJustificativa  String?         @db.Text
  assinaturaComprovanteUrl String?

  motivoExclusao           String?         @db.Text

  jornalQueue              JornalQueue?
}

// Atualizar User para ter a relação inversa
model User {
  id            String    @id @default(cuid())
  name          String?
  username        String   @unique
  email         String?   @unique
  password        String
  cpf             String?  @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("USER")             // ADMIN_GERAL, ADMIN_SETORIAL, USER
  ativo           Boolean  @default(true)
  pinSeguranca  String?   // B1: token gerado para ações destrutivas críticas pelo Admin
  permissoesExtra String[] @default([])
  setorId       String?
  secretariaId  String?
  setor         Setor?    @relation(fields: [setorId], references: [id])
  secretaria    Secretaria? @relation("MembrosSecretaria", fields: [secretariaId], references: [id])
  secretariasTitular Secretaria[] @relation("SecretarioTitular")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  portarias          Portaria[] @relation("CriadoPor")
  portariasRevisadas Portaria[] @relation("RevisorAtual")
  portariasAssinadas Portaria[] @relation("AssinadoPor")
  atividades      FeedAtividade[]
  llmPromptsCriados LlmPrompt[] @relation("LlmPromptsCriados")
}

model FeedAtividade {
  id           String    @id @default(cuid())
  tipoEvento   String
  mensagem     String    @db.Text
  portariaId   String?
  autorId      String
  secretariaId String?
  setorId      String?
  portaria     Portaria? @relation(fields: [portariaId], references: [id])
  autor        User      @relation(fields: [autorId], references: [id])
  metadata     Json      @default("{}")
  createdAt    DateTime  @default(now())
}

model ModeloDocumento {
  id              String           @id @default(cuid())
  nome            String
  descricao       String
  tipoDocumento   TipoDocumento    @default(PORTARIA)
  secretariaId    String?
  docxTemplateUrl String
  conteudoHtml    String           @default("") @db.Text
  ativo           Boolean          @default(true)
  versao          Int              @default(1)
  modeloPaiId     String?
  modeloPai       ModeloDocumento?  @relation("Versoes", fields: [modeloPaiId], references: [id])
  versoes         ModeloDocumento[] @relation("Versoes")
  variaveis       ModeloVariavel[]
  portarias       Portaria[]
}

model ModeloVariavel {
  id          String          @id @default(cuid())
  modeloId    String
  modelo      ModeloDocumento @relation(fields: [modeloId], references: [id])
  chave       String
  label       String
  tipo        String          @default("texto")
  opcoes      String[]        @default([])
  obrigatorio Boolean         @default(true)
  ordem       Int             @default(0)
  valorPadrao String?         // B1: valor pré-preenchido no formulário de portaria
  grupo            String?         // B3: agrupa campos em seções no formulário de portaria
  regraCondicional Json?           // B2: { dependeDe: "CHAVE", valor: "valor" } — exibe campo só se condição satisfeita
}

model VariavelSistema {
  id                       String  @id @default(cuid())
  chave                    String  @unique
  valor                    String
  descricao                String
  resolvidaAutomaticamente Boolean @default(false)
}

model Secretaria {
  id        String   @id @default(cuid())
  nome      String
  sigla     String   @unique
  cor       String   @default("#6366f1")
  titularId String?
  titular   User?    @relation("SecretarioTitular", fields: [titularId], references: [id])
  setores   Setor[]
  usuarios  User[]   @relation("MembrosSecretaria")
  portarias Portaria[]
  ativo     Boolean  @default(true)
}

model Setor {
  id           String     @id @default(cuid())
  nome         String
  sigla        String
  secretariaId String
  secretaria   Secretaria @relation(fields: [secretariaId], references: [id])
  usuarios     User[]
  portarias    Portaria[]
  ativo        Boolean    @default(true)
  
  @@unique([secretariaId, sigla])
}

enum TipoDocumento {
  PORTARIA
  MEMORANDO
  OFICIO
  LEI
}

model JornalQueue {
  id              String        @id @default(cuid())
  portariaId      String        @unique
  tipoDocumento   TipoDocumento @default(PORTARIA)
  numeroSugerido  String?
  numeroFinal     String?
  status          String        @default("PENDENTE") // PENDENTE, CONCLUIDA
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  portaria        Portaria      @relation(fields: [portariaId], references: [id], onDelete: Cascade)
}

model LlmApiKey {
  id           String    @id @default(cuid())
  provider     String    // "groq" | "openrouter" | "cerebras" | "mistral"
  label        String    // Ex: "Groq - Conta TI Prefeitura"
  keyEncrypted String    @unique // Chave real (nunca exposta ao front)
  mask         String    // Ex: "gsk-••••••••1234" (exibição no painel)
  ativo        Boolean   @default(true)
  requisicoes  Int       @default(0)
  tokensTotal  Int       @default(0)
  esgotada     Boolean   @default(false)
  esgotadaAte  DateTime? // null = disponível, preenchido = cooldown ativo
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt
}

// ── Prompts de Treinamento da IA ──────────────────────────────────────────────
// Permite que admins criem e gerenciem prompts personalizados injetados no sistema.
// São combinados com o system prompt base antes de cada chamada ao LLM.
model LlmPrompt {
  id           String   @id @default(cuid())
  nome         String   // Nome amigável, ex: "Instruções de Revisão"
  categoria    String   // "SISTEMA" | "PORTARIA" | "REVISAO" | "CHAT_GERAL" | "MODELO" | "CUSTOM"
  conteudo     String   @db.Text // Texto do prompt (pode ser longo)
  ativo        Boolean  @default(true)
  ordem        Int      @default(0) // Menor = injetado primeiro
  criadoPorId  String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  criadoPor    User?    @relation("LlmPromptsCriados", fields: [criadoPorId], references: [id], onDelete: SetNull)
}
